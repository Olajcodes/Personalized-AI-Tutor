# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/mastery_ai

# Auth
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
ENV=dev

# AI Core integration (set in cloud env)
AI_CORE_BASE_URL=
AI_CORE_TIMEOUT_SECONDS=8
AI_CORE_ALLOW_FALLBACK=true

# CORS (comma-separated list or JSON array; use * only for quick dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# Optional dependency endpoints (used by /system/health)
REDIS_URL=
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
USE_NEO4J_GRAPH=false
VECTOR_DB_URL=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=MasteryAI
QDRANT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_API_BASE=
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-20b
LLM_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
CURRICULUM_CONCEPT_USE_LLM=false
CURRICULUM_CONCEPT_LLM_MODEL=openai/gpt-oss-20b

# Internal graph client
INTERNAL_GRAPH_BASE_URL=http://127.0.0.1:8000/api/v1/internal/graph
INTERNAL_GRAPH_TIMEOUT_SECONDS=5
INTERNAL_GRAPH_MAX_RETRIES=2
