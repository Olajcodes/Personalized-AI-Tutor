# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/mastery_ai

# Auth
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
ENV=dev

# AI Core integration (set in cloud env)
AI_CORE_BASE_URL=http://127.0.0.1:10001
AI_CORE_TIMEOUT_SECONDS=40
AI_CORE_ALLOW_FALLBACK=true

# CORS (comma-separated list or JSON array; use * only for quick dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173
INTERNAL_SERVICE_KEY=change_me_internal_service_key
PREWARM_QUEUE_ENABLED=true
PREWARM_WORKER_ENABLED=true
PREWARM_WORKER_POLL_SECONDS=5
PREWARM_WORKER_BATCH_SIZE=3
TUTOR_ACTION_PREWARM_ENABLED=true

# Optional dependency endpoints (used by /system/health)
REDIS_URL=redis://127.0.0.1:6379/0
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=olayiwola
USE_NEO4J_GRAPH=true
VECTOR_DB_URL=
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=MasteryAI
QDRANT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_API_BASE=
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-20b
LESSON_LLM_MODEL=
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
LESSON_OPENAI_FALLBACK_ENABLED=true
LESSON_OPENAI_FALLBACK_MODEL=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
CURRICULUM_CONCEPT_USE_LLM=true
CURRICULUM_CONCEPT_EXTRACT_USE_LLM=true
CURRICULUM_CONCEPT_LLM_MODEL=openai/gpt-oss-20b
CURRICULUM_PREREQ_USE_LLM=true
CURRICULUM_PREREQ_LLM_MODEL=
CURRICULUM_PREREQ_TEXT_MAX_CHARS=3000

# Internal graph client
INTERNAL_GRAPH_BASE_URL=http://127.0.0.1:8001/api/v1/internal/graph
INTERNAL_GRAPH_TIMEOUT_SECONDS=5
INTERNAL_GRAPH_MAX_RETRIES=2
