# ===== Runtime =====
PORT=10000
CORS_ORIGINS=*

# ===== LLM =====
# Provider: groq | openai
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-20b
# Use one of these keys based on provider:
GROQ_API_KEY=your_groq_key_here
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
LLM_OPENAI_FALLBACK_ENABLED=true
# Optional override for Groq OpenAI-compatible endpoint
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ===== Internal Backend RAG =====
BACKEND_INTERNAL_RAG_URL=http://127.0.0.1:8000/api/v1/internal/rag/retrieve
BACKEND_INTERNAL_POSTGRES_URL=http://127.0.0.1:8000/api/v1/internal/postgres
BACKEND_INTERNAL_GRAPH_CONTEXT_URL=http://127.0.0.1:8000/api/v1/internal/graph/context
INTERNAL_RAG_TIMEOUT_SECONDS=6
INTERNAL_CONTEXT_TIMEOUT_SECONDS=5
INTERNAL_RAG_TOP_K=6

# ===== Datastores =====
# Preferred DSN for ai-core
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/mastery_ai
# Optional fallback alias used by ai-core if POSTGRES_DSN is missing
DATABASE_URL=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Optional cache
REDIS_URL=redis://localhost:6379/0

# ===== Vector Store (Qdrant) =====
VECTOR_DB_PROVIDER=qdrant
# Optional legacy alias still supported by ai-core:
# VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=MasteryAI
QDRANT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Optional fallback alias for collection:
# VECTOR_INDEX_NAME=MasteryAI
# Optional fallback alias for embedding:
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ===== Safety =====
ENABLE_BASIC_MODERATION=true
MAX_INPUT_CHARS=6000

# ===== Observability =====
LOG_LEVEL=INFO
COST_TRACKING_ENABLED=true
