# ===== Models =====
LLM_PROVIDER=groq  #openai
LLM_MODEL=openai/gpt-oss-20b    #gpt-4o-mini
LLM_API_KEY=your_key_here
GROQ_API_KEY=your_groq_key_here
PORT=10000
CORS_ORIGINS=*
BACKEND_INTERNAL_RAG_URL=http://127.0.0.1:8000/api/v1/internal/rag/retrieve
INTERNAL_RAG_TIMEOUT_SECONDS=6
INTERNAL_RAG_TOP_K=6

# ===== Datastores =====
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/mastery_ai
# For shared-team setup, set this equal to backend DATABASE_URL.
# If POSTGRES_DSN is omitted, ai-core will fallback to DATABASE_URL (if provided).

# For Neo4j 
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
REDIS_URL=redis://localhost:6379/0

# ===== RAG / Vector store =====
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=MasteryAI
QDRANT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ===== Safety =====
ENABLE_BASIC_MODERATION=true
MAX_INPUT_CHARS=6000

# ===== Observability =====
LOG_LEVEL=INFO
COST_TRACKING_ENABLED=true
